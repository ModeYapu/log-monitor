export interface StepResult { step: string; passed: boolean; details: string; }

export async function run(page: Page, baseUrl: string): Promise<StepResult[]> {
  const results: StepResult[] = [];

  // Navigate to first page
  await page.goto(baseUrl + '/users', { waitUntil: 'networkidle', timeout: 15000 });
  await page.waitForTimeout(2000);


  // Step 1: Verify list has rows
  try {
    const rows = page.locator('.el-table__row, tr');
    const count = await rows.count();
    const hasData = count > 0;
    results.push({ step: 'verify list', passed: hasData, details: count + ' rows found' });
  } catch (e) { results.push({ step: 'verify list', passed: false, details: String(e) }); }

  return results;
}
